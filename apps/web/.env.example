# Ascend Web App Environment Variables
# Copy to .env.local and fill in real values.

# Database
DATABASE_URL=postgresql://ascend:password@localhost:5432/ascend

# API key (used by MCP clients and legacy web auth)
API_KEY=
NEXT_PUBLIC_API_KEY=

# Auth (Phase 6)
AUTH_JWT_SECRET=<minimum 32 bytes of randomness; generate via: openssl rand -base64 48>
# Optional:
AUTH_REFRESH_TOKEN_PEPPER=
COOKIE_DOMAIN=

# File storage (Phase 7: presigned R2 upload)
# Cloudflare dashboard -> R2 -> Create bucket -> Generate S3-compatible API token.
# R2_ACCOUNT_ID is the Cloudflare account id (visible in the dashboard URL after /accounts/).
# R2_PUBLIC_URL is optional (the bucket's public URL if public access is enabled;
# not needed for presigned uploads, only for serving files publicly later).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ascend-files-dev
R2_PUBLIC_URL=

# CRDT / Hocuspocus (Wave 8 Phase 4)
# Shared secret for signing CRDT JWTs (min 32 chars; generate via: openssl rand -hex 32)
CRDT_JWT_SECRET=
# Shared secret for authenticating Hocuspocus persistence calls (generate via: openssl rand -hex 32)
CRDT_PERSIST_SECRET=
# WebSocket URL of the Hocuspocus CRDT server (wss:// in production, ws:// in local dev)
CRDT_WS_URL=wss://crdt.ascend.nativeai.agency

# MCP CORS (Wave 8b)
# Comma-separated list of allowed origins for the /api/mcp endpoint.
# If unset, defaults to wildcard (*) for dev backward compatibility.
# In production, restrict to your app domain and any MCP client origins.
# Example: MCP_ALLOWED_ORIGINS=https://ascend.nativeai.agency,https://claude.ai
MCP_ALLOWED_ORIGINS=

# Wave 10: AES-256-GCM key for credential-at-rest encryption (PATs, API keys)
# REQUIRED. 64 hex chars = 32 bytes. Generate via: openssl rand -hex 32
# MUST be distinct from AUTH_JWT_SECRET / CRDT_JWT_SECRET / CRDT_PERSIST_SECRET.
SECRETS_ENCRYPTION_KEY=
