// Ascend: Goal tracking app
// Prisma 7 schema with complete data models

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum Horizon {
  YEARLY
  QUARTERLY
  MONTHLY
  WEEKLY
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum TodoStatus {
  PENDING
  DONE
  SKIPPED
}

enum FileStatus {
  PENDING
  UPLOADED
  FAILED
}

enum ContextEntryType {
  NOTE
  SOURCE
  PROJECT
  PERSON
  DECISION
  QUESTION
  AREA
}

enum ContextLinkType {
  REFERENCES
  EXTENDS
  CONTRADICTS
  SUPPORTS
  EXAMPLE_OF
  DERIVED_FROM
  SUPERSEDES
  APPLIES_TO
  PART_OF
}

enum ContextLinkSource {
  CONTENT
  MANUAL
}

enum ChatProviderKind {
  GEMINI
  OPENAI
  ANTHROPIC
}

// Models

model User {
  id                 String   @id @default(cuid())
  email              String?  @unique
  name               String?
  apiKey             String   @unique @default(cuid())
  passwordHash       String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Wave 0: workspace scaffolding (nullable until Wave 8 backfill)
  workspaceId String?

  goals          Goal[]
  categories     Category[]
  todos          Todo[]
  contextEntries ContextEntry[]
  stats          UserStats?
  xpEvents       XpEvent[]
  focusSessions  FocusSession[]
  files          File[]
  sessions       Session[]
  contextLinks   ContextLink[]
  settings       UserSettings?
  contextMaps    ContextMap?
  llmUsage       LlmUsage[]
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  horizon     Horizon
  status      GoalStatus @default(NOT_STARTED)
  priority    Priority   @default(MEDIUM)

  // Adjacency list hierarchy (self-reference)
  parentId String?
  parent   Goal?   @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Goal[]  @relation("GoalHierarchy")

  // Category
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // SMART fields
  specific   String?
  measurable String?
  attainable String?
  relevant   String?
  timely     String?

  // Progress tracking
  progress     Int     @default(0)
  targetValue  Float?
  currentValue Float?
  unit         String?

  // Dates
  startDate   DateTime?
  deadline    DateTime?
  completedAt DateTime?

  // Ordering
  sortOrder Int @default(0)

  // Notes
  notes String?

  // Recurring goal fields
  isRecurring           Boolean             @default(false)
  recurringFrequency    RecurringFrequency?
  recurringInterval     Int?                @default(1)
  recurringSourceId     String?
  recurringSource       Goal?               @relation("RecurringInstances", fields: [recurringSourceId], references: [id], onDelete: SetNull)
  recurringInstances    Goal[]              @relation("RecurringInstances")
  currentStreak         Int                 @default(0)
  longestStreak         Int                 @default(0)
  lastCompletedInstance DateTime?

  // Wave 0: workspace scaffolding (nullable until Wave 8 backfill)
  workspaceId String?

  // Relations
  progressLogs  ProgressLog[]
  todos         Todo[]
  focusSessions FocusSession[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([userId])
  @@index([parentId])
  @@index([categoryId])
  @@index([horizon, userId])
  @@index([status, userId])
  @@index([deadline])
  @@index([recurringSourceId])
}

model Category {
  id     String  @id @default(cuid())
  userId String
  name   String
  color  String  @default("#4F46E5")
  icon   String?

  // Hierarchy (self-reference for unlimited nesting)
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")

  // Ordering
  sortOrder Int @default(0)

  // Wave 0: workspace scaffolding (nullable until Wave 8 backfill)
  workspaceId String?

  // Relations
  goals          Goal[]
  todos          Todo[]
  contextEntries ContextEntry[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Constraints
  @@unique([userId, name, parentId])
  @@index([userId])
  @@index([parentId])
}

model ProgressLog {
  id        String   @id @default(cuid())
  goalId    String
  value     Float
  note      String?
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([createdAt])
}

model UserStats {
  id            String    @id @default(cuid())
  userId        String    @unique
  totalXp       Int       @default(0)
  level         Int       @default(1)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  weeklyScore   Int       @default(0)
  weekStartDate DateTime?
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  source    String
  goalId    String?
  // Optional link back to the originating todo so completion can be
  // reversed cleanly by todoService.uncomplete (the inverse deletes the
  // XpEvent row by this foreign key).
  todoId    String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  todo Todo? @relation(fields: [todoId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([todoId])
}

model FocusSession {
  id              String   @id @default(cuid())
  userId          String
  todoId          String?
  goalId          String?
  durationSeconds Int
  mode            String   // "focus" or "break"
  startedAt       DateTime
  endedAt         DateTime
  createdAt       DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  todo Todo? @relation(fields: [todoId], references: [id], onDelete: SetNull)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([todoId])
  @@index([goalId])
  @@index([startedAt])
}

model Todo {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  status      TodoStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)

  // Goal link (input to output connection)
  goalId String?
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  // Category
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Scheduling
  dueDate       DateTime?
  scheduledDate DateTime?

  // Recurrence
  isRecurring        Boolean @default(false)
  recurrenceRule     String?
  recurringSourceId  String?
  recurringSource    Todo?   @relation("RecurringTodos", fields: [recurringSourceId], references: [id], onDelete: SetNull)
  recurringInstances Todo[]  @relation("RecurringTodos")

  // Streak tracking
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastCompletedDate DateTime?
  consistencyScore  Float     @default(0)

  // Daily Big 3
  isBig3   Boolean   @default(false)
  big3Date DateTime?

  // Ordering
  sortOrder Int @default(0)

  // Completion
  completedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Wave 0: workspace scaffolding (nullable until Wave 8 backfill)
  workspaceId String?

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpEvents      XpEvent[]
  focusSessions FocusSession[]

  // Indexes
  @@index([userId])
  @@index([goalId])
  @@index([categoryId])
  @@index([dueDate])
  @@index([scheduledDate])
  @@index([status, userId])
  @@index([recurringSourceId])
  @@index([isBig3, big3Date, userId])
}

// =====================================================================
//  WARNING: ContextEntry has a `search_vector` tsvector column PLUS a
//  GIN index and a BEFORE INSERT/UPDATE trigger added by a raw SQL
//  migration (prisma/migrations/20260409114539_add_context_fts).
//
//  Prisma does NOT know about the column, the index, or the trigger.
//
//  DO NOT run `npx prisma db push` or `npx prisma migrate reset` — both
//  will silently drop everything and break full-text search. When you
//  modify this model, ALWAYS inspect the generated migration SQL and
//  confirm it does NOT contain `DROP COLUMN "search_vector"`,
//  `DROP INDEX "ContextEntry_search_vector_idx"`, or any drop of the
//  `context_entry_search_vector_update` trigger/function before
//  running `prisma migrate dev`. See CLAUDE.md safety rule 6.
//
//  The column is queried via $queryRaw in lib/services/context-service.ts
//  (the `search` method). The trigger maintains it automatically on
//  every INSERT/UPDATE of title/content/tags.
// =====================================================================
model ContextEntry {
  id      String @id @default(cuid())
  userId  String
  title   String
  content String // Markdown content (the document body)

  // Category (reuses existing Category model for tree navigation)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Tags for cross-cutting discovery (stored as string array)
  tags String[] @default([])

  // Pinned entries surface at the top of the context list
  isPinned Boolean @default(false)

  // Entry type for typed knowledge graph
  type ContextEntryType @default(NOTE)

  // Wave 2: pgvector embedding for semantic search (1536-dim, Gemini Embedding 2)
  // Populated asynchronously by embeddingService after create/update.
  // Queried via raw SQL ($queryRaw) since Prisma does not natively support pgvector.
  embedding Unsupported("vector(1536)")?

  // Wave 0: workspace scaffolding (nullable until Wave 8 backfill)
  workspaceId String?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Graph edges
  outgoingLinks ContextLink[] @relation("ContextLinkFrom")
  incomingLinks ContextLink[] @relation("ContextLinkTo")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([userId])
  @@index([categoryId])
  @@index([userId, title])
  @@index([userId, isPinned])
}

model ContextLink {
  id          String            @id @default(cuid())
  userId      String
  fromEntryId String
  toEntryId   String
  type        ContextLinkType   @default(REFERENCES)
  source      ContextLinkSource @default(CONTENT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  fromEntry ContextEntry @relation("ContextLinkFrom", fields: [fromEntryId], references: [id], onDelete: Cascade)
  toEntry   ContextEntry @relation("ContextLinkTo", fields: [toEntryId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([fromEntryId, toEntryId, type])
  @@index([userId])
  @@index([fromEntryId])
  @@index([toEntryId])
  @@index([type])
}

model File {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Storage
  storageKey String     // S3/R2 key, e.g., "users/<userId>/<uuid>.pdf"
  bucket     String     @default("ascend-files")
  mimeType   String
  sizeBytes  BigInt

  // Identity
  filename   String
  sha256     String?    // Content hash for deduplication (v1+)

  // Lifecycle
  uploadedAt DateTime?
  status     FileStatus @default(PENDING)

  // Wave 0: workspace scaffolding (nullable until Wave 8 backfill)
  workspaceId String?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId, status])
  @@index([sha256])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Refresh token family (for rotation + reuse detection)
  familyId         String
  refreshTokenHash String    @unique  // SHA-256 of current refresh token
  expiresAt        DateTime
  revokedAt        DateTime?

  // Client metadata
  userAgent        String?
  ipAddress        String?
  deviceName       String?

  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

// =====================================================================
//  Wave 2: AI-native tables
// =====================================================================

model UserSettings {
  id           String           @id @default(cuid())
  userId       String           @unique
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // AI preferences
  chatProvider ChatProviderKind @default(GEMINI)
  chatModel    String?          // null = resolve to provider's default model at runtime

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ContextMap {
  id           String           @id @default(cuid())
  userId       String           @unique
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Synthesized map content: { themes, principles, projects, tensions, orphans }
  content      Json

  // LLM metadata for the generation that produced this map
  provider     ChatProviderKind
  model        String
  inputTokens  Int
  outputTokens Int
  costCents    Int

  generatedAt  DateTime         @default(now())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model LlmUsage {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider           ChatProviderKind
  model              String
  purpose            String           // "map_refresh", "embedding", "suggest_connections", etc.
  promptTokens       Int
  completionTokens   Int
  estimatedCostCents Int

  createdAt          DateTime         @default(now())

  @@index([userId, createdAt])
}
