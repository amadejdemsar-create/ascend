// Ascend: Goal tracking app
// Prisma 7 schema with complete data models

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum Horizon {
  YEARLY
  QUARTERLY
  MONTHLY
  WEEKLY
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum TodoStatus {
  PENDING
  DONE
  SKIPPED
}

// Models

model User {
  id                 String   @id @default(cuid())
  email              String?  @unique
  name               String?
  apiKey             String   @unique @default(cuid())
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  goals          Goal[]
  categories     Category[]
  todos          Todo[]
  contextEntries ContextEntry[]
  stats          UserStats?
  xpEvents       XpEvent[]
  focusSessions  FocusSession[]
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  horizon     Horizon
  status      GoalStatus @default(NOT_STARTED)
  priority    Priority   @default(MEDIUM)

  // Adjacency list hierarchy (self-reference)
  parentId String?
  parent   Goal?   @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Goal[]  @relation("GoalHierarchy")

  // Category
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // SMART fields
  specific   String?
  measurable String?
  attainable String?
  relevant   String?
  timely     String?

  // Progress tracking
  progress     Int     @default(0)
  targetValue  Float?
  currentValue Float?
  unit         String?

  // Dates
  startDate   DateTime?
  deadline    DateTime?
  completedAt DateTime?

  // Ordering
  sortOrder Int @default(0)

  // Notes
  notes String?

  // Recurring goal fields
  isRecurring           Boolean             @default(false)
  recurringFrequency    RecurringFrequency?
  recurringInterval     Int?                @default(1)
  recurringSourceId     String?
  recurringSource       Goal?               @relation("RecurringInstances", fields: [recurringSourceId], references: [id], onDelete: SetNull)
  recurringInstances    Goal[]              @relation("RecurringInstances")
  currentStreak         Int                 @default(0)
  longestStreak         Int                 @default(0)
  lastCompletedInstance DateTime?

  // Relations
  progressLogs  ProgressLog[]
  todos         Todo[]
  focusSessions FocusSession[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([userId])
  @@index([parentId])
  @@index([categoryId])
  @@index([horizon, userId])
  @@index([status, userId])
  @@index([deadline])
  @@index([recurringSourceId])
}

model Category {
  id     String  @id @default(cuid())
  userId String
  name   String
  color  String  @default("#4F46E5")
  icon   String?

  // Hierarchy (self-reference for unlimited nesting)
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")

  // Ordering
  sortOrder Int @default(0)

  // Relations
  goals          Goal[]
  todos          Todo[]
  contextEntries ContextEntry[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Constraints
  @@unique([userId, name, parentId])
  @@index([userId])
  @@index([parentId])
}

model ProgressLog {
  id        String   @id @default(cuid())
  goalId    String
  value     Float
  note      String?
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([createdAt])
}

model UserStats {
  id            String    @id @default(cuid())
  userId        String    @unique
  totalXp       Int       @default(0)
  level         Int       @default(1)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  weeklyScore   Int       @default(0)
  weekStartDate DateTime?
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  source    String
  goalId    String?
  // Optional link back to the originating todo so completion can be
  // reversed cleanly by todoService.uncomplete (the inverse deletes the
  // XpEvent row by this foreign key).
  todoId    String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  todo Todo? @relation(fields: [todoId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([todoId])
}

model FocusSession {
  id              String   @id @default(cuid())
  userId          String
  todoId          String?
  goalId          String?
  durationSeconds Int
  mode            String   // "focus" or "break"
  startedAt       DateTime
  endedAt         DateTime
  createdAt       DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  todo Todo? @relation(fields: [todoId], references: [id], onDelete: SetNull)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([todoId])
  @@index([goalId])
  @@index([startedAt])
}

model Todo {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  status      TodoStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)

  // Goal link (input to output connection)
  goalId String?
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  // Category
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Scheduling
  dueDate       DateTime?
  scheduledDate DateTime?

  // Recurrence
  isRecurring        Boolean @default(false)
  recurrenceRule     String?
  recurringSourceId  String?
  recurringSource    Todo?   @relation("RecurringTodos", fields: [recurringSourceId], references: [id], onDelete: SetNull)
  recurringInstances Todo[]  @relation("RecurringTodos")

  // Streak tracking
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastCompletedDate DateTime?
  consistencyScore  Float     @default(0)

  // Daily Big 3
  isBig3   Boolean   @default(false)
  big3Date DateTime?

  // Ordering
  sortOrder Int @default(0)

  // Completion
  completedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpEvents      XpEvent[]
  focusSessions FocusSession[]

  // Indexes
  @@index([userId])
  @@index([goalId])
  @@index([categoryId])
  @@index([dueDate])
  @@index([scheduledDate])
  @@index([status, userId])
  @@index([recurringSourceId])
  @@index([isBig3, big3Date, userId])
}

// =====================================================================
//  WARNING: ContextEntry has a `search_vector` tsvector column PLUS a
//  GIN index and a BEFORE INSERT/UPDATE trigger added by a raw SQL
//  migration (prisma/migrations/20260409114539_add_context_fts).
//
//  Prisma does NOT know about the column, the index, or the trigger.
//
//  DO NOT run `npx prisma db push` or `npx prisma migrate reset` — both
//  will silently drop everything and break full-text search. When you
//  modify this model, ALWAYS inspect the generated migration SQL and
//  confirm it does NOT contain `DROP COLUMN "search_vector"`,
//  `DROP INDEX "ContextEntry_search_vector_idx"`, or any drop of the
//  `context_entry_search_vector_update` trigger/function before
//  running `prisma migrate dev`. See CLAUDE.md safety rule 6.
//
//  The column is queried via $queryRaw in lib/services/context-service.ts
//  (the `search` method). The trigger maintains it automatically on
//  every INSERT/UPDATE of title/content/tags.
// =====================================================================
model ContextEntry {
  id      String @id @default(cuid())
  userId  String
  title   String
  content String // Markdown content (the document body)

  // Category (reuses existing Category model for tree navigation)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Tags for cross-cutting discovery (stored as string array)
  tags String[] @default([])

  // Pinned entries surface at the top of the context list
  isPinned Boolean @default(false)

  // Backlinks: store IDs of documents this entry links TO via [[Title]] syntax
  // Bidirectional resolution happens at query time (find entries linking to me)
  linkedEntryIds String[] @default([])

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([userId])
  @@index([categoryId])
  @@index([userId, title])
  @@index([userId, isPinned])
}
