# Hocuspocus CRDT server port (default: 1234)
PORT=1234

# Secret for verifying CRDT JWTs issued by the web app (must match apps/web CRDT_JWT_SECRET; min 32 chars)
CRDT_JWT_SECRET=

# Base URL of the Ascend web app (used for initial state hydration and persistence callbacks)
WEB_APP_BASE_URL=https://ascend.nativeai.agency

# Shared secret for authenticating persistence POST calls to the web app (must match apps/web CRDT_PERSIST_SECRET)
CRDT_PERSIST_SECRET=

# Database URL (read-only; reserved for future direct-DB hydration of initial state.
# Phase 4 uses HTTP GET to WEB_APP_BASE_URL/api/blockdocs/[entryId]/state for initial state.
# Not used in Phase 4.)
DATABASE_URL=
